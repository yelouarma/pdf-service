        "express": "^4.18.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.5",
        "@types/react": "^18.2.48",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
